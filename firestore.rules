rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Fields:
    //   - title: string (required)
    //   - slug: string (required)
    //   - type: string (required, enum: charmes, bracelets)
    //   - price_xpf: number (required)
    //   - description: string
    //   - is_active: bool
    //   - photos_png: list of strings
    //   - createdAt: timestamp
    //   - updatedAt: timestamp
    //
    // Collection: stores
    // Fields:
    //   - name: string (required)
    //   - hours: string (required)
    //   - google_maps_url: string
    //   - phone: string
    //   - email: string
    //   - messenger_url: string
    //   - notes: string
    //
    // Collection: faqs
    // Fields:
    //   - order: int (required)
    //   - question: string (required)
    //   - answer: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      // For the "Secret Code" flow, we allow any authenticated user.
      // The UI is guarded by the secret code, which triggers anonymous auth.
      return isAuthenticated();
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['title', 'slug', 'type', 'price_xpf']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.slug is string && data.slug.size() > 0 && data.slug.size() < 100 &&
             data.type in ['charmes', 'bracelets'] &&
             data.price_xpf is number && data.price_xpf >= 0 &&
             (!('description' in data) || (data.description is string && data.description.size() < 2000)) &&
             (!('is_active' in data) || data.is_active is bool) &&
             (!('photos_png' in data) || data.photos_png is list);
    }

    function isValidStore(data) {
      return data.keys().hasAll(['name', 'hours']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.hours is string && data.hours.size() > 0 && data.hours.size() < 500;
    }

    function isValidFaq(data) {
      return data.keys().hasAll(['order', 'question', 'answer']) &&
             data.order is int &&
             data.question is string && data.question.size() > 0 && data.question.size() < 500 &&
             data.answer is string && data.answer.size() > 0 && data.answer.size() < 2000;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Products
    match /products/{productId} {
      allow read: if true; // Publicly readable for the catalogue
      allow create: if isAdmin() && isValidProduct(request.resource.data);
      allow update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    // Stores
    match /stores/{storeId} {
      allow read: if true;
      allow create: if isAdmin() && isValidStore(request.resource.data);
      allow update: if isAdmin() && isValidStore(request.resource.data);
      allow delete: if isAdmin();
    }

    // FAQs
    match /faqs/{faqId} {
      allow read: if true;
      allow create: if isAdmin() && isValidFaq(request.resource.data);
      allow update: if isAdmin() && isValidFaq(request.resource.data);
      allow delete: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
